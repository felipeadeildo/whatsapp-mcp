# MCP Server Configuration
MCP_API_KEY=your-secret-api-key-here
MCP_PORT=8080

# Logging Configuration
LOG_LEVEL=INFO

# Timezone Configuration
# defaults to UTC
TIMEZONE=America/Sao_Paulo

# Media Download Configuration
# Enable/disable automatic media download when messages arrive
MEDIA_AUTO_DOWNLOAD_ENABLED=true

# Enable/disable automatic media download from HistorySync events
# HistorySync can trigger hundreds of downloads simultaneously causing 403 errors
# Set to false to only download media from new incoming messages
MEDIA_AUTO_DOWNLOAD_FROM_HISTORY=false

# Maximum file size for auto-download in MB (0 = unlimited)
MEDIA_AUTO_DOWNLOAD_MAX_SIZE_MB=10

# Comma-separated list of media types to auto-download
# Options: image, video, audio, document, sticker, ptt, gif
MEDIA_AUTO_DOWNLOAD_TYPES=image,audio,sticker

# Webhook Configuration (optional)
# Primary webhook URL - message events will be sent here automatically
# Leave empty to disable webhooks
WEBHOOK_URL=

# Advanced webhook settings
# Maximum number of delivery retry attempts (default: 3)
WEBHOOK_MAX_RETRIES=3

# HTTP request timeout in seconds (default: 10)
WEBHOOK_TIMEOUT_SECONDS=10

# Number of concurrent webhook delivery workers (default: 3)
WEBHOOK_WORKER_POOL_SIZE=3

# Whisper.cpp Transcription Configuration
# Absolute paths to whisper-cli binary and ggml model
WHISPER_BIN=
WHISPER_MODEL=
# ISO 639-1 language code (default: pt)
WHISPER_LANGUAGE=pt
# CPU threads passed to whisper -t (default: 4; set to logical processor count for max throughput)
WHISPER_THREADS=4
# Timeout for the transcription pipeline in seconds (default: 300)
# Decouples whisper from the MCP RPC timeout so long voice notes don't get killed.
TRANSCRIBE_TIMEOUT_SECONDS=300

# OpenRouter STT (preferred transcription backend)
# When OPENROUTER_API_KEY is set, transcription uses OpenRouter (whisper-large-v3)
# instead of CPU-bound local whisper.cpp. It parallelizes across providers, fixing the
# burst bottleneck (many concurrent voice notes). Audio is sent with data_collection=deny
# so providers won't train on / retain it. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# STT model slug (default: openai/whisper-large-v3)
OPENROUTER_STT_MODEL=openai/whisper-large-v3
# Backend: auto (OpenRouter if key present, else local) | openrouter (force) | local (force)
TRANSCRIBE_BACKEND=auto
# Max concurrent OpenRouter calls in a batch transcription (default 8, clamped 1..32)
TRANSCRIBE_BATCH_CONCURRENCY=8